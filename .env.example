# Required environment variables
# Copy this file to .env.local and fill in your values

# Deepgram — transcription
# https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Gemini — prompt generation and feedback
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override Gemini model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Supabase — sessions and auth
# https://app.supabase.com → project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# PostHog — analytics
# https://app.posthog.com → project settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Application URL (use localhost for local dev)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Development flags (optional)
# USE_FIXTURE=false         — set true to skip Deepgram and use mock transcript
# SKIP_GEMINI_PROMPTS=false — set true to use hardcoded fallback prompts (no Gemini calls)
